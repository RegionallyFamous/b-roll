{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/plugins.php",
    "preferredVersions": {
        "php": "8.0",
        "wp": "latest"
    },
    "login": true,
    "steps": [
        {
            "step": "installPlugin",
            "pluginData": {
                "resource": "url",
                "url": "https://github.com/WordPress/desktop-mode/releases/download/v0.5.0/wp-desktop-mode.zip"
            },
            "options": { "activate": true }
        },
        {
            "step": "activatePlugin",
            "pluginPath": "b-roll/b-roll.php"
        },
        {
            "step": "updateUserMeta",
            "userId": 1,
            "meta": { "wp_desktop_mode": "1" }
        }
    ]
}
