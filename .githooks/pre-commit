#!/usr/bin/env bash
# ODD pre-commit hook.
#
# Mirrors the `check-version` step the release workflow runs on a tag
# push, but at commit time — catches the "Version: header bumped, but
# ODD_VERSION left behind" class of mistake locally instead of burning
# a tag cycle.
#
# Install with: git config core.hooksPath .githooks
# Skip with:    git commit --no-verify

set -e

root="$(git rev-parse --show-toplevel)"
changed="$(git diff --cached --name-only)"

# Only run when the plugin manifest is in the commit — any other commit
# is fine regardless of version coherency.
if ! grep -qxF "odd/odd.php" <<< "$changed"; then
    exit 0
fi

if ! "$root/odd/bin/check-version"; then
    echo "" >&2
    echo "pre-commit: version strings in odd/odd.php are out of sync." >&2
    echo "  -> bump both the 'Version:' header and the ODD_VERSION constant." >&2
    echo "  -> or use 'git commit --no-verify' to skip this check." >&2
    exit 1
fi
