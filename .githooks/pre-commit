#!/usr/bin/env bash
# ODD pre-commit hook.
#
# Mirrors the `check-version` step the release workflow runs on a tag
# push, but at commit time — catches the "Version: header bumped, but
# ODD_VERSION left behind" class of mistake locally instead of burning
# a tag cycle.
#
# Install with: git config core.hooksPath .githooks
# Skip with:    git commit --no-verify

set -e

root="$(git rev-parse --show-toplevel)"
changed="$(git diff --cached --name-only)"

# Only run when a version-bearing file is in the commit — any other
# commit is fine regardless of version coherency. Included files:
#   odd/odd.php   — Version: header + ODD_VERSION constant
#   blueprint.json — ?v=<x.y.z> cache-buster on the ODD ZIP URL
if ! grep -qxE "odd/odd\.php|blueprint\.json" <<< "$changed"; then
    exit 0
fi

if ! "$root/odd/bin/check-version"; then
    echo "" >&2
    echo "pre-commit: ODD version strings are out of sync." >&2
    echo "  -> bump ALL of:" >&2
    echo "       * 'Version:' header in odd/odd.php" >&2
    echo "       * ODD_VERSION constant in odd/odd.php" >&2
    echo "       * ?v=<x.y.z> query on the odd.zip URL in blueprint.json" >&2
    echo "  -> or use 'git commit --no-verify' to skip this check." >&2
    exit 1
fi
