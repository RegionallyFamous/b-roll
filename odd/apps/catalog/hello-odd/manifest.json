{
  "slug":        "hello-odd",
  "name":        "Hello ODD",
  "version":     "1.0.0",
  "author":      "ODD",
  "description": "A minimal reference app. Opens a tiny window, greets you, and registers one muse line and one slash command.",
  "icon":        "icon.svg",
  "entry":       "index.html",
  "capability":  "read",
  "window": {
    "width":      520,
    "height":     360,
    "min_width":  360,
    "min_height": 260
  },
  "desktopIcon": {
    "position": 300
  },
  "extensions": {
    "muses": [
      {
        "slug":  "hello-odd",
        "label": "Hello",
        "voice": {
          "appOpen": {
            "hello-odd": [
              "Hello. Seen you before.",
              "A greeting. Understated."
            ]
          },
          "appClose": {
            "hello-odd": [
              "Goodbye. Gently."
            ]
          }
        }
      }
    ],
    "commands": [
      {
        "slug":  "hello-odd",
        "label": "Hello ODD",
        "hint":  "Open the Hello ODD reference app",
        "run":   "odd.apps.open:hello-odd"
      }
    ]
  }
}
