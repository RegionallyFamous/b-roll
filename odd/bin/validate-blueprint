#!/usr/bin/env python3
"""Validate ODD's public Playground blueprint for reliability regressions.

Background
----------
`blueprint.json` at the repo root is what Playground executes when
somebody opens the public demo URL. Any step that depends on a
browser-blocked URL, a wiggly `releases/latest/download` redirect, or
an unpinned plugin install turns the first-run experience into a CORS
failure — and that's typically the first thing a new user ever sees.

This script parses the blueprint and fails on known-fragile patterns so
regressions are caught before they reach `main`.

Checks (all emit bullets; any failure → exit code 1):

  1. `blueprint.json` exists and parses as JSON.
  2. No `installPlugin` step uses `github.com/*/releases/latest/download/…`.
     GitHub serves those as 302 redirects into asset-service hosts that
     have unreliable CORS headers from the Playground origin.
  3. Every `git:directory` installPlugin resource has:
        - `ref`   (tag / branch / SHA)
        - `refType` (one of `tag`, `branch`, `commit`, `refname`)
        - `path`  (use `/` for repo-root plugins)
     Unpinned `ref` lets the demo silently drift when upstream `main`
     changes — and when that drift includes a broken PHP file, every
     new Playground load fatals.
  4. Every `git:directory` installPlugin has `options.targetFolderName`.
     Without it, Playground guesses folder names from the repo slug,
     which can collide with `Requires Plugins:` expectations in the
     plugin headers.
  5. Any `installPlugin` with `resource: "url"` must be HTTPS and
     cannot point at `github.com/*/releases/latest/download/…`.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path


HERE = Path(__file__).resolve().parent
REPO_ROOT = HERE.parent.parent
BLUEPRINT = REPO_ROOT / "blueprint.json"


def fail(problems: list[str]) -> None:
    print("blueprint validation failed:", file=sys.stderr)
    for p in problems:
        print(f"  - {p}", file=sys.stderr)
    sys.exit(1)


def main() -> int:
    problems: list[str] = []

    if not BLUEPRINT.exists():
        fail([f"{BLUEPRINT} not found — reliability gate cannot run."])
        return 1

    try:
        data = json.loads(BLUEPRINT.read_text())
    except json.JSONDecodeError as e:
        fail([f"{BLUEPRINT} did not parse as JSON: {e}"])
        return 1

    steps = data.get("steps")
    if not isinstance(steps, list) or not steps:
        problems.append("blueprint has no steps array")

    allowed_ref_types = {"tag", "branch", "commit", "refname"}

    for idx, step in enumerate(steps or []):
        if not isinstance(step, dict):
            problems.append(f"step[{idx}] is not an object")
            continue
        if step.get("step") != "installPlugin":
            continue
        plugin = step.get("pluginData")
        if not isinstance(plugin, dict):
            problems.append(f"step[{idx}].pluginData is not an object")
            continue

        resource = plugin.get("resource", "")
        options = step.get("options") or {}

        if resource == "url":
            url = str(plugin.get("url", ""))
            if "github.com" in url and "/releases/latest/download" in url:
                problems.append(
                    f"step[{idx}] installs from github.com/.../releases/latest/download — "
                    "CORS-blocked from Playground, pin to a specific release tag or use git:directory"
                )
            if not url.startswith("https://"):
                problems.append(
                    f"step[{idx}] resource=url must be https, got {url!r}"
                )

        elif resource == "git:directory":
            if not plugin.get("ref"):
                problems.append(
                    f"step[{idx}] git:directory resource is missing `ref` — "
                    "pin to a tag, branch, or SHA so the demo is deterministic"
                )
            ref_type = plugin.get("refType")
            if ref_type not in allowed_ref_types:
                problems.append(
                    f"step[{idx}] git:directory resource has refType={ref_type!r}; "
                    f"allowed: {sorted(allowed_ref_types)}"
                )
            if "path" not in plugin:
                problems.append(
                    f"step[{idx}] git:directory resource must specify `path` (use '/' for repo-root plugins)"
                )
            if not options.get("targetFolderName"):
                problems.append(
                    f"step[{idx}] git:directory installPlugin must set options.targetFolderName "
                    "so the plugin folder matches what `Requires Plugins:` expects"
                )

    if problems:
        fail(problems)
        return 1

    print(f"blueprint ok: {len(steps or [])} steps, no CORS-fragile or unpinned dependencies")
    return 0


if __name__ == "__main__":
    sys.exit(main())
