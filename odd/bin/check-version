#!/usr/bin/env python3
"""Assert the Version header, ODD_VERSION constant, and blueprint cache-buster agree.

With --expect <x.y.z>, also assert all three match that value (used by
the release workflow to assert the pushed tag matches every declared
version).

Checks:
  - `Version:` header in odd/odd.php
  - `ODD_VERSION` constant in odd/odd.php
  - `?v=<x.y.z>` query string on the ODD ZIP URL in blueprint.json
    (so Playground's service worker re-fetches the plugin after each
    release instead of serving a cached copy keyed on a static URL)

Usage:
    odd/bin/check-version
    odd/bin/check-version --expect 0.1.0
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
PLUGIN = PLUGIN_DIR / "odd.php"
REPO_ROOT = PLUGIN_DIR.parent
BLUEPRINT = REPO_ROOT / "blueprint.json"


SENTINEL_GIT_DIRECTORY = "__git_directory__"


def blueprint_cachebuster() -> str | None:
    """Inspect how blueprint.json installs the ODD plugin.

    Returns one of:
      - a `?v=<x.y.z>` value if the blueprint pins ODD to a release ZIP
        with a cache-buster (legacy strategy)
      - SENTINEL_GIT_DIRECTORY if the blueprint pulls ODD via a
        `git:directory` resource against `RegionallyFamous/odd`. Git
        resources are version-checked by branch/tag, not URL string,
        so we don't need to keep a cache-buster in sync with odd.php.
      - "" if the URL form is present but missing its `v=` query
        param (treated as an error at the call site).
      - None if no recognizable ODD install step is present.
    """
    if not BLUEPRINT.exists():
        return None
    try:
        data = json.loads(BLUEPRINT.read_text())
    except json.JSONDecodeError:
        return None
    for step in data.get("steps", []):
        if not isinstance(step, dict) or step.get("step") != "installPlugin":
            continue
        plugin_data = step.get("pluginData") or {}
        resource = plugin_data.get("resource")
        if resource == "git:directory":
            repo = plugin_data.get("url", "")
            if "RegionallyFamous/odd" in repo:
                return SENTINEL_GIT_DIRECTORY
            continue
        url = plugin_data.get("url", "")
        if "odd.zip" not in url or "RegionallyFamous/odd" not in url:
            continue
        match = re.search(r"[?&]v=([0-9]+\.[0-9]+\.[0-9]+)(?:[&#]|$)", url)
        if match:
            return match.group(1)
        return ""
    return None


def main() -> int:
    parser = argparse.ArgumentParser(description="Check that ODD versions are in sync.")
    parser.add_argument("--expect", help="also assert all match this value", default=None)
    args = parser.parse_args()

    if not PLUGIN.exists():
        print(f"error: missing {PLUGIN}", file=sys.stderr)
        return 1

    text = PLUGIN.read_text()

    header = re.search(r"^\s*\*\s*Version:\s*([0-9]+\.[0-9]+\.[0-9]+)\s*$", text, re.MULTILINE)
    constant = re.search(
        r"define\(\s*['\"]ODD_VERSION['\"]\s*,\s*['\"]([0-9]+\.[0-9]+\.[0-9]+)['\"]\s*\)",
        text,
    )

    found: dict[str, str | None] = {
        "Version: header": header.group(1) if header else None,
        "ODD_VERSION": constant.group(1) if constant else None,
    }

    cachebuster = blueprint_cachebuster()
    if cachebuster is None:
        print(
            "error: could not find the ODD installPlugin step in blueprint.json",
            file=sys.stderr,
        )
        return 1
    if cachebuster == "":
        print(
            "error: blueprint.json's odd.zip URL is missing its ?v=<version> "
            "cache-buster — Playground's service worker will serve a stale "
            "plugin ZIP until the URL string changes. Add ?v=<current-version>.",
            file=sys.stderr,
        )
        return 1

    if cachebuster != SENTINEL_GIT_DIRECTORY:
        found["blueprint ?v="] = cachebuster

    missing = [k for k, v in found.items() if v is None]
    if missing:
        for k in missing:
            print(f"error: could not find {k}", file=sys.stderr)
        return 1

    unique = set(found.values())
    if len(unique) != 1:
        print("error: version strings disagree:", file=sys.stderr)
        for k, v in found.items():
            print(f"  {k}: {v}", file=sys.stderr)
        return 1

    version = next(iter(unique))

    if args.expect is not None and version != args.expect:
        print(
            f"error: committed version is {version} but expected {args.expect}",
            file=sys.stderr,
        )
        return 1

    if cachebuster == SENTINEL_GIT_DIRECTORY:
        print(
            f"OK: odd.php version {version} (blueprint installs ODD via git:directory@main)"
        )
    else:
        print(f"OK: odd.php + blueprint.json version {version}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
