#!/usr/bin/env python3
"""Validate the ODD Discover catalog: every row points at real files.

Entries in `odd/apps/catalog/registry.json` reference two kinds of asset
for each bundle:
  - `icon_url`     — a small SVG preview tile
  - `download_url` — the `.wp` archive the "Install" button downloads

Both are usually `raw.githubusercontent.com/RegionallyFamous/odd/main/`
URLs that resolve back into this repo under `odd/apps/catalog/`. When
someone adds a row without landing the matching file, the Discover
shelf looks fine on the shop surface but every install 404s in the
user's browser. This validator is how CI catches that regression.

Checks, per row in `apps[]` and `bundles[]`:
  1. `download_url` + `icon_url` pointing into this repo resolve to an
     existing file on disk.
  2. Each `.wp` archive:
        a. opens as a valid ZIP,
        b. contains `manifest.json`,
        c. that manifest's `slug` matches the registry row's `slug`,
        d. that manifest's `type` matches the registry row's `type`
           (for `bundles[]`; `apps[]` is always type `app`),
        e. that manifest's `version` matches the registry row's.

Exits non-zero on any mismatch, with a list of every problem found.
Intended for CI, the release workflow, and local pre-push.
"""
from __future__ import annotations

import io
import json
import sys
import zipfile
from pathlib import Path
from typing import Any
from urllib.parse import urlparse


HERE = Path(__file__).resolve().parent
PLUGIN_DIR = HERE.parent
REPO_ROOT = PLUGIN_DIR.parent
REGISTRY = PLUGIN_DIR / "apps" / "catalog" / "registry.json"

# Any URL starting with this prefix must resolve to a real file under
# $REPO_ROOT on disk. Everything else (third-party CDN, plugin author's
# own bucket, etc.) is left alone — we can't check what's hosted
# elsewhere, and it would be wrong to try.
REPO_PREFIX = "https://raw.githubusercontent.com/RegionallyFamous/odd/main/"


def load_registry() -> tuple[dict[str, Any] | None, list[str]]:
    problems: list[str] = []
    if not REGISTRY.is_file():
        problems.append(f"missing registry: {REGISTRY.relative_to(REPO_ROOT)}")
        return None, problems
    try:
        data = json.loads(REGISTRY.read_text(encoding="utf-8"))
    except json.JSONDecodeError as err:
        problems.append(f"registry is not valid JSON: {err}")
        return None, problems
    if not isinstance(data, dict):
        problems.append("registry must be a JSON object")
        return None, problems
    return data, problems


def repo_path_for(url: str) -> Path | None:
    """Return the on-disk `Path` for a raw.githubusercontent repo URL,
    or `None` if the URL is not one of ours."""
    if not isinstance(url, str) or not url.startswith(REPO_PREFIX):
        return None
    rel = url[len(REPO_PREFIX):]
    # Strip any fragment / query — the serving side ignores them.
    parsed = urlparse("https://example.com/" + rel)
    rel = parsed.path.lstrip("/")
    return REPO_ROOT / rel


def check_url_on_disk(url: str, label: str, slug: str, problems: list[str]) -> Path | None:
    """Resolve the URL to a repo file. Records a problem if the URL is
    a repo URL but the file is missing. Returns the Path if resolvable,
    else None."""
    if not isinstance(url, str) or url == "":
        problems.append(f"[{slug}] {label} is empty")
        return None
    path = repo_path_for(url)
    if path is None:
        # Not a repo-hosted URL — outside our validator's scope.
        return None
    if not path.is_file():
        problems.append(
            f"[{slug}] {label} points at {url}\n"
            f"    expected on disk: {path.relative_to(REPO_ROOT)}  (missing)"
        )
        return None
    return path


def check_bundle_archive(
    wp_path: Path,
    row: dict[str, Any],
    expected_type: str,
    problems: list[str],
) -> None:
    slug = row.get("slug", "?")
    try:
        raw = wp_path.read_bytes()
    except OSError as err:
        problems.append(f"[{slug}] could not read {wp_path.relative_to(REPO_ROOT)}: {err}")
        return

    try:
        zf = zipfile.ZipFile(io.BytesIO(raw), "r")
    except zipfile.BadZipFile as err:
        problems.append(f"[{slug}] {wp_path.relative_to(REPO_ROOT)} is not a valid ZIP: {err}")
        return

    try:
        if "manifest.json" not in zf.namelist():
            problems.append(
                f"[{slug}] {wp_path.relative_to(REPO_ROOT)} has no manifest.json"
            )
            return
        try:
            manifest_raw = zf.read("manifest.json").decode("utf-8")
            manifest = json.loads(manifest_raw)
        except (UnicodeDecodeError, json.JSONDecodeError) as err:
            problems.append(
                f"[{slug}] {wp_path.relative_to(REPO_ROOT)} manifest.json is not valid JSON: {err}"
            )
            return
    finally:
        zf.close()

    if not isinstance(manifest, dict):
        problems.append(f"[{slug}] manifest.json is not a JSON object")
        return

    manifest_slug = manifest.get("slug", "")
    if manifest_slug != slug:
        problems.append(
            f"[{slug}] manifest.slug mismatch — archive says {manifest_slug!r}, "
            f"registry says {slug!r}"
        )

    # The plugin accepts `iconset` as an alias for `icon-set` on read,
    # so normalise before comparing.
    manifest_type = str(manifest.get("type", "app") or "app").lower()
    if manifest_type == "iconset":
        manifest_type = "icon-set"
    if manifest_type != expected_type:
        problems.append(
            f"[{slug}] manifest.type mismatch — archive says {manifest_type!r}, "
            f"registry says {expected_type!r}"
        )

    registry_version = str(row.get("version", "") or "")
    manifest_version = str(manifest.get("version", "") or "")
    if registry_version and manifest_version and registry_version != manifest_version:
        problems.append(
            f"[{slug}] version mismatch — archive says {manifest_version!r}, "
            f"registry says {registry_version!r}"
        )


def main() -> int:
    problems: list[str] = []

    data, load_problems = load_registry()
    problems.extend(load_problems)
    if data is None:
        for p in problems:
            print(f"error: {p}", file=sys.stderr)
        return 1

    rows: list[tuple[dict[str, Any], str]] = []
    for app in data.get("apps", []) or []:
        if isinstance(app, dict):
            rows.append((app, "app"))
    for entry in data.get("bundles", []) or []:
        if isinstance(entry, dict):
            etype = str(entry.get("type", "") or "").strip().lower()
            if etype == "iconset":
                etype = "icon-set"
            rows.append((entry, etype))

    for row, expected_type in rows:
        slug = row.get("slug") or "?"
        icon_path = check_url_on_disk(row.get("icon_url", ""), "icon_url", slug, problems)
        wp_path = check_url_on_disk(row.get("download_url", ""), "download_url", slug, problems)
        if wp_path is not None:
            if not wp_path.name.endswith(".wp"):
                problems.append(
                    f"[{slug}] download_url must point at a .wp archive, got {wp_path.name}"
                )
            else:
                check_bundle_archive(wp_path, row, expected_type, problems)
        # `icon_path` is intentionally unused after existence check —
        # SVG content scrubbing happens at install time on the server.
        _ = icon_path

    if problems:
        print("catalog validation failed:", file=sys.stderr)
        for p in problems:
            print(f"  - {p}", file=sys.stderr)
        return 1

    total_rows = len(rows)
    print(f"  catalog ok — {total_rows} row(s) validated")
    return 0


if __name__ == "__main__":
    sys.exit(main())
