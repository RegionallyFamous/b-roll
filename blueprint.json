{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-desktop/",
  "preferredVersions": {
    "php": "8.0",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://odd.regionallyfamous.com/vendor/desktop-mode-v0.6.0.zip"
      },
      "options": { "activate": true, "targetFolderName": "desktop-mode" }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/RegionallyFamous/odd",
        "ref": "main",
        "refType": "branch",
        "path": "odd"
      },
      "options": { "activate": true, "targetFolderName": "odd" }
    },
    {
      "step": "updateUserMeta",
      "userId": 1,
      "meta": { "desktop_mode_mode": "1" }
    }
  ]
}
