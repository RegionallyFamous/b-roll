{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/",
  "preferredVersions": {
    "php": "8.0",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/WordPress/desktop-mode/releases/download/v0.5.0/wp-desktop-mode.zip"
      },
      "options": { "activate": true }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/RegionallyFamous/b-roll/releases/latest/download/b-roll.zip"
      },
      "options": { "activate": true }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/RegionallyFamous/b-roll/releases/download/b-roll-icons-v0.1.2/b-roll-icons.zip"
      },
      "options": { "activate": true }
    },
    {
      "step": "updateUserMeta",
      "userId": 1,
      "meta": { "wp_desktop_mode": "1" }
    },
    {
      "step": "writeFile",
      "path": "/wordpress/wp-content/mu-plugins/b-roll-playground-defaults.php",
      "data": "<?php\n/**\n * B-Roll Playground demo: pre-select the B-Roll wallpaper.\n *\n * WP Desktop Mode fires `wp_desktop_default_wallpaper` when a user has\n * no saved OS settings yet. Returning `b-roll` here makes the shell\n * boot straight into the animated wallpaper instead of the default\n * dark slab.\n */\nadd_filter( 'wp_desktop_default_wallpaper', static function () {\n\treturn 'b-roll';\n} );\n"
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; if ( function_exists( 'wpdm_save_os_settings' ) ) { wpdm_save_os_settings( 1, array( 'wallpaper' => 'b-roll' ) ); }"
    }
  ]
}
