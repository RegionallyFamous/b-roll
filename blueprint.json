{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/",
  "preferredVersions": {
    "php": "8.0",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/WordPress/desktop-mode/releases/download/v0.5.0/wp-desktop-mode.zip"
      },
      "options": { "activate": true }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/RegionallyFamous/b-roll/releases/download/v0.1.0/b-roll.zip"
      },
      "options": { "activate": true }
    },
    {
      "step": "updateUserMeta",
      "userId": 1,
      "meta": { "wp_desktop_mode": "1" }
    }
  ]
}
