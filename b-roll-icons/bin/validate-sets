#!/usr/bin/env python3
"""Validate every installed icon set.

Run before every release:
    bin/validate-sets

Checks per set:
  - manifest.json parses + has slug, label, franchise, accent, icons dict
  - every icon referenced in manifest.json#icons exists on disk
  - every on-disk *.svg parses as well-formed XML
  - svg root element is <svg ...> with width/height or viewBox
  - no control-character junk inside <title> (bit us once in v0.1.0)

Exits 0 if every set validates, 1 otherwise. CI reads the exit code.
"""
from __future__ import annotations

import json
import re
import sys
import xml.etree.ElementTree as ET
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
SETS_DIR = ROOT / "sets"


def validate_svg(path: Path) -> list[str]:
    errs: list[str] = []
    try:
        raw = path.read_bytes()
    except Exception as e:  # pragma: no cover
        return [f"unreadable: {e}"]
    for b in raw:
        if b < 0x20 and b not in (0x09, 0x0A, 0x0D):
            errs.append(f"control byte 0x{b:02x} in file body (strips to ASCII or strip)")
            break
    try:
        tree = ET.fromstring(raw)
    except ET.ParseError as e:
        errs.append(f"not well-formed XML: {e}")
        return errs
    tag = tree.tag.rsplit("}", 1)[-1]
    if tag != "svg":
        errs.append(f"root element is <{tag}>, expected <svg>")
    if not (tree.get("viewBox") or (tree.get("width") and tree.get("height"))):
        errs.append("<svg> needs viewBox or width+height")
    return errs


def validate_set(set_dir: Path) -> list[str]:
    slug = set_dir.name
    errs: list[str] = []
    manifest_path = set_dir / "manifest.json"
    if not manifest_path.is_file():
        return [f"{slug}: missing manifest.json"]
    try:
        manifest = json.loads(manifest_path.read_text())
    except Exception as e:
        return [f"{slug}: manifest.json invalid JSON: {e}"]

    for key in ("slug", "label", "franchise", "accent", "icons"):
        if key not in manifest:
            errs.append(f"{slug}: manifest.json missing required key '{key}'")
    if manifest.get("slug") != slug:
        errs.append(
            f"{slug}: manifest.slug is '{manifest.get('slug')}' but directory is '{slug}'"
        )
    if "accent" in manifest and not re.match(r"^#[0-9A-Fa-f]{3,8}$", str(manifest["accent"])):
        errs.append(f"{slug}: accent must be a #hex color, got '{manifest['accent']}'")

    icons = manifest.get("icons", {})
    if not isinstance(icons, dict) or not icons:
        errs.append(f"{slug}: manifest.icons must be a non-empty object")
        return errs

    seen_files: set[str] = set()
    for key, rel in icons.items():
        if not isinstance(rel, str) or not rel:
            errs.append(f"{slug}.icons['{key}']: must be a non-empty relative path")
            continue
        if "/" in rel or ".." in rel:
            errs.append(f"{slug}.icons['{key}']: paths must be flat filenames, got '{rel}'")
            continue
        seen_files.add(rel)
        icon_path = set_dir / rel
        if not icon_path.is_file():
            errs.append(f"{slug}.icons['{key}']: file '{rel}' not on disk")
            continue
        if icon_path.suffix.lower() == ".svg":
            for e in validate_svg(icon_path):
                errs.append(f"{slug}.icons['{key}'] ({rel}): {e}")

    # Warn on orphan SVGs (on disk but not referenced by manifest). Not
    # fatal — helps authors notice when they forgot to hook something up.
    for svg in set_dir.glob("*.svg"):
        if svg.name not in seen_files:
            errs.append(f"{slug}: SVG on disk not referenced by manifest: {svg.name}")

    return errs


def main() -> int:
    if not SETS_DIR.is_dir():
        print("no sets/ directory found", file=sys.stderr)
        return 1
    all_errs: list[str] = []
    count = 0
    for set_dir in sorted(SETS_DIR.iterdir()):
        if not set_dir.is_dir() or set_dir.name.startswith("."):
            continue
        count += 1
        all_errs.extend(validate_set(set_dir))

    if all_errs:
        for e in all_errs:
            print(f"error: {e}")
        return 1
    print(f"OK: {count} icon set(s) validated")
    return 0


if __name__ == "__main__":
    sys.exit(main())
