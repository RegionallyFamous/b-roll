#!/usr/bin/env python3
"""Build dist/b-roll-icons.zip from the b-roll-icons/ tree.

Mirrors the ergonomic of ../bin/build-zip: excludes dev-only files,
caps on a size budget so a silent payload regression trips hard.

Usage:
    b-roll-icons/bin/build-zip [--max-bytes N]
"""
from __future__ import annotations

import argparse
import sys
import zipfile
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
DIST = ROOT.parent / "dist"
ZIP_NAME = "b-roll-icons.zip"

# ~2 MB budget. v0.1.0 ships ~112 KB (13 SVGs + ~15 KB of PHP/JS +
# README), leaving plenty of headroom for ~10 future sets at ~100 KB
# each. Bump the budget when we start shipping PNG fallbacks.
DEFAULT_MAX_BYTES = 2 * 1024 * 1024

EXCLUDE_TOP_LEVEL = {"bin"}

EXCLUDE_SUFFIXES = {".pyc"}

EXCLUDE_NAMES = {".DS_Store"}


def should_include(rel: Path) -> bool:
    parts = rel.parts
    if not parts:
        return False
    if parts[0] in EXCLUDE_TOP_LEVEL:
        return False
    if rel.name in EXCLUDE_NAMES:
        return False
    if rel.suffix in EXCLUDE_SUFFIXES:
        return False
    return True


def main() -> int:
    parser = argparse.ArgumentParser(description="Build the B-Roll Icons release zip.")
    parser.add_argument(
        "--max-bytes",
        type=int,
        default=DEFAULT_MAX_BYTES,
    )
    args = parser.parse_args()

    DIST.mkdir(parents=True, exist_ok=True)
    out = DIST / ZIP_NAME
    if out.exists():
        out.unlink()

    count = 0
    with zipfile.ZipFile(out, "w", zipfile.ZIP_DEFLATED) as zf:
        for path in sorted(ROOT.rglob("*")):
            if not path.is_file():
                continue
            rel = path.relative_to(ROOT)
            if not should_include(rel):
                continue
            # Arcname uses 'b-roll-icons/' prefix so the zip unpacks as
            # a WordPress plugin directory.
            arcname = Path("b-roll-icons") / rel
            zf.write(path, arcname=str(arcname))
            count += 1

    size = out.stat().st_size
    pct = (size / args.max_bytes) * 100
    print(f"  wrote dist/{ZIP_NAME}  ({count} files, {size:,} bytes, {pct:.1f}% of budget)")

    if size > args.max_bytes:
        print(
            f"error: zip size {size:,} exceeds budget {args.max_bytes:,} bytes",
            file=sys.stderr,
        )
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
