#!/usr/bin/env python3
"""Build dist/b-roll.zip from the current working tree.

Excludes development-only files (CI configs, dev tooling, dotfiles,
build output). Fails if the resulting zip exceeds MAX_ZIP_BYTES so a
silent payload-doubling regression can't ship unnoticed.

Usage:
    bin/build-zip [--max-bytes N]
"""
from __future__ import annotations

import argparse
import os
import sys
import zipfile
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
DIST = ROOT / "dist"
ZIP_NAME = "b-roll.zip"

# ~7 MB budget. Current payload is ~4.7 MB; this leaves ~50% headroom
# but trips hard if someone accidentally commits, say, a PNG asset.
DEFAULT_MAX_BYTES = 7 * 1024 * 1024

EXCLUDE_TOP_LEVEL = {
    ".git",
    ".github",
    ".claude",
    ".cursor",
    "bin",
    "tools",
    "ci",
    "dist",
    "node_modules",
    "vendor",
}

EXCLUDE_SUFFIXES = {
    ".pyc",
}

EXCLUDE_NAMES = {
    ".DS_Store",
    ".gitignore",
    ".eslintrc.json",
    "package.json",
    "package-lock.json",
    "composer.json",
    "composer.lock",
    "phpcs.xml.dist",
    "CLAUDE.md",
}


def should_include(rel: Path) -> bool:
    parts = rel.parts
    if not parts:
        return False
    if parts[0] in EXCLUDE_TOP_LEVEL:
        return False
    if rel.name in EXCLUDE_NAMES:
        return False
    if rel.suffix in EXCLUDE_SUFFIXES:
        return False
    return True


def main() -> int:
    parser = argparse.ArgumentParser(description="Build the B-Roll release zip.")
    parser.add_argument(
        "--max-bytes",
        type=int,
        default=DEFAULT_MAX_BYTES,
        help=f"fail if the zip exceeds this many bytes (default {DEFAULT_MAX_BYTES})",
    )
    args = parser.parse_args()

    DIST.mkdir(parents=True, exist_ok=True)
    out = DIST / ZIP_NAME
    if out.exists():
        out.unlink()

    count = 0
    with zipfile.ZipFile(out, "w", zipfile.ZIP_DEFLATED) as zf:
        for path in sorted(ROOT.rglob("*")):
            if not path.is_file():
                continue
            rel = path.relative_to(ROOT)
            if not should_include(rel):
                continue
            # Arcname uses the 'b-roll/' prefix so the zip unpacks as a
            # WordPress plugin directory.
            arcname = Path("b-roll") / rel
            zf.write(path, arcname=str(arcname))
            count += 1

    size = out.stat().st_size
    pct = (size / args.max_bytes) * 100
    print(f"  wrote {out.relative_to(ROOT)}  ({count} files, {size:,} bytes, {pct:.1f}% of budget)")

    if size > args.max_bytes:
        print(
            f"error: zip size {size:,} exceeds budget {args.max_bytes:,} bytes",
            file=sys.stderr,
        )
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
