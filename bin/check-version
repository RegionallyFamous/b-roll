#!/usr/bin/env python3
"""Assert the three version strings in b-roll.php are in sync.

CLAUDE.md: "Version lives in three places - keep in sync on release:
the `Version:` header in `b-roll.php`, the version string in
`wp_enqueue_script`, and the `'version'` value in `wp_localize_script`."

With --expect <x.y.z>, also assert that all three match that value
(used by the release workflow to assert the pushed tag matches).

Usage:
    bin/check-version
    bin/check-version --expect 0.7.0
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
PLUGIN = ROOT / "b-roll.php"


def main() -> int:
    parser = argparse.ArgumentParser(description="Check that b-roll.php versions are in sync.")
    parser.add_argument("--expect", help="also assert all three match this value", default=None)
    args = parser.parse_args()

    if not PLUGIN.exists():
        print(f"error: missing {PLUGIN.relative_to(ROOT)}", file=sys.stderr)
        return 1

    text = PLUGIN.read_text()

    header = re.search(r"^\s*\*\s*Version:\s*([0-9]+\.[0-9]+\.[0-9]+)\s*$", text, re.MULTILINE)
    enqueue = re.search(
        r"wp_enqueue_script\s*\(.*?['\"]([0-9]+\.[0-9]+\.[0-9]+)['\"]\s*,\s*true\s*\)",
        text,
        re.DOTALL,
    )
    localize = re.search(r"['\"]version['\"]\s*=>\s*['\"]([0-9]+\.[0-9]+\.[0-9]+)['\"]", text)

    found = {
        "Version: header": header.group(1) if header else None,
        "wp_enqueue_script": enqueue.group(1) if enqueue else None,
        "wp_localize_script version": localize.group(1) if localize else None,
    }

    missing = [k for k, v in found.items() if v is None]
    if missing:
        for k in missing:
            print(f"error: could not find {k} in b-roll.php", file=sys.stderr)
        return 1

    unique = set(found.values())
    if len(unique) != 1:
        print("error: version strings disagree:", file=sys.stderr)
        for k, v in found.items():
            print(f"  {k}: {v}", file=sys.stderr)
        return 1

    version = next(iter(unique))

    if args.expect is not None and version != args.expect:
        print(
            f"error: committed version is {version} but expected {args.expect}",
            file=sys.stderr,
        )
        return 1

    print(f"OK: b-roll.php version {version}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
