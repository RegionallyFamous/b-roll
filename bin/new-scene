#!/usr/bin/env python3
"""Scaffold a new B-Roll scene.

Writes a starter src/scenes/<slug>.js, appends a row to src/scenes.json,
and prints the asset paths you still need to provide.

Usage:
    bin/new-scene <slug> "<Label>" "<Franchise>" tag1,tag2,tag3 [#fallbackColor]
"""
from __future__ import annotations

import json
import re
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
SCENES_DIR = ROOT / "src" / "scenes"
MANIFEST = ROOT / "src" / "scenes.json"
PREVIEWS = ROOT / "assets" / "previews"
WALLPAPERS = ROOT / "assets" / "wallpapers"

SCENE_STUB = """\
/**
 * B-Roll scene: {label} ({franchise})
 * ---------------------------------------------------------------
 * Painted backdrop at assets/wallpapers/{slug}.jpg. Add Pixi
 * motion overlays here; see existing scenes for patterns.
 */
( function () {{
\t'use strict';
\twindow.__bRoll = window.__bRoll || {{}};
\twindow.__bRoll.scenes = window.__bRoll.scenes || {{}};
\tvar h = window.__bRoll.helpers;

\tfunction backdropUrl() {{
\t\tvar cfg = window.bRoll || {{}};
\t\tvar qs = cfg.version ? '?v=' + encodeURIComponent( cfg.version ) : '';
\t\treturn ( cfg.pluginUrl || '' ) + '/assets/wallpapers/{slug}.jpg' + qs;
\t}}

\twindow.__bRoll.scenes[ '{slug}' ] = {{
\t\tsetup: async function ( env ) {{
\t\t\tvar PIXI = env.PIXI, app = env.app;

\t\t\tvar tex = await PIXI.Assets.load( backdropUrl() );
\t\t\tvar backdrop = new PIXI.Sprite( tex );
\t\t\tapp.stage.addChild( backdrop );
\t\t\tfunction fitBackdrop() {{
\t\t\t\tvar s = Math.max(
\t\t\t\t\tapp.renderer.width  / tex.width,
\t\t\t\t\tapp.renderer.height / tex.height
\t\t\t\t);
\t\t\t\tbackdrop.scale.set( s );
\t\t\t\tbackdrop.x = ( app.renderer.width  - tex.width  * s ) / 2;
\t\t\t\tbackdrop.y = ( app.renderer.height - tex.height * s ) / 2;
\t\t\t}}
\t\t\tfitBackdrop();

\t\t\treturn {{ backdrop: backdrop, tex: tex, fitBackdrop: fitBackdrop }};
\t\t}},
\t\ttick: function ( state, env ) {{ /* animate overlays here */ }},
\t\tonResize: function ( state, env ) {{ state.fitBackdrop(); }},
\t\tcleanup: function ( state, env ) {{ /* release scene-owned resources */ }},
\t}};
}} )();
"""


def die(msg: str) -> None:
    sys.stderr.write(f"error: {msg}\n")
    sys.exit(2)


def slug_is_valid(slug: str) -> bool:
    return bool(re.fullmatch(r"[a-z][a-z0-9-]*", slug))


def main(argv: list[str]) -> int:
    if len(argv) < 5:
        die("usage: bin/new-scene <slug> <label> <franchise> <tag1,tag2,...> [#fallback]")

    slug, label, franchise, tag_csv = argv[1], argv[2], argv[3], argv[4]
    fallback = argv[5] if len(argv) > 5 else "#111111"

    if not slug_is_valid(slug):
        die(f"invalid slug '{slug}' (lowercase kebab-case)")

    scene_path = SCENES_DIR / f"{slug}.js"
    if scene_path.exists():
        die(f"scene file already exists: {scene_path.relative_to(ROOT)}")

    manifest = json.loads(MANIFEST.read_text())
    if any(entry["slug"] == slug for entry in manifest):
        die(f"manifest already has slug: {slug}")

    tags = [t.strip() for t in tag_csv.split(",") if t.strip()]
    if not tags:
        die("at least one tag is required")

    manifest.append(
        {
            "slug": slug,
            "label": label,
            "franchise": franchise,
            "tags": tags,
            "fallbackColor": fallback,
            "added": _current_version(),
        }
    )

    scene_path.parent.mkdir(parents=True, exist_ok=True)
    scene_path.write_text(SCENE_STUB.format(slug=slug, label=label, franchise=franchise))

    MANIFEST.write_text(json.dumps(manifest, indent=4) + "\n")

    preview = PREVIEWS / f"{slug}.jpg"
    wallpaper = WALLPAPERS / f"{slug}.jpg"

    print(f"  wrote {scene_path.relative_to(ROOT)}")
    print(f"  appended entry to {MANIFEST.relative_to(ROOT)}")
    print()
    print("Still needed:")
    if not preview.exists():
        print(f"  - {preview.relative_to(ROOT)}  (painterly thumbnail, ~640x400, JPG q75)")
    if not wallpaper.exists():
        print(f"  - {wallpaper.relative_to(ROOT)}  (painted backdrop, 1920x1080, JPG q80)")
    print()
    print("Then run: bin/validate-scenes")
    return 0


def _current_version() -> str:
    plugin_php = ROOT / "b-roll.php"
    try:
        text = plugin_php.read_text()
    except OSError:
        return "0.0.0"
    match = re.search(r"Version:\s*([0-9]+\.[0-9]+\.[0-9]+)", text)
    return match.group(1) if match else "0.0.0"


if __name__ == "__main__":
    sys.exit(main(sys.argv))
