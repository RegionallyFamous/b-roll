#!/usr/bin/env python3
"""Validate blueprint.json: parseable, required keys, known steps.

With --online, also HEAD-check the installPlugin URLs resolve (used by
the release workflow to confirm the just-published zip is reachable).

Usage:
    bin/check-blueprint
    bin/check-blueprint --online
"""
from __future__ import annotations

import argparse
import json
import sys
import urllib.error
import urllib.request
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
BLUEPRINT = ROOT / "blueprint.json"

REQUIRED_TOP_KEYS = ("steps", "landingPage")
KNOWN_STEPS = {
    "installPlugin",
    "installTheme",
    "updateUserMeta",
    "login",
    "runPHP",
    "setSiteOptions",
    "writeFile",
    "runWpInstallationWizard",
    "activatePlugin",
    "activateTheme",
    "mkdir",
    "cp",
    "mv",
    "rm",
    "unzip",
    "defineWpConfigConsts",
}


def check_url(url: str) -> str | None:
    req = urllib.request.Request(url, method="HEAD")
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            if 200 <= resp.status < 400:
                return None
            return f"status {resp.status}"
    except urllib.error.HTTPError as err:
        if 300 <= err.code < 400:
            return None
        return f"HTTP {err.code}"
    except Exception as err:  # noqa: BLE001
        return str(err)


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate blueprint.json.")
    parser.add_argument("--online", action="store_true", help="also HEAD-check plugin URLs")
    args = parser.parse_args()

    if not BLUEPRINT.exists():
        print(f"error: missing {BLUEPRINT.relative_to(ROOT)}", file=sys.stderr)
        return 1

    try:
        data = json.loads(BLUEPRINT.read_text())
    except json.JSONDecodeError as err:
        print(f"error: blueprint.json is not valid JSON: {err}", file=sys.stderr)
        return 1

    problems: list[str] = []

    for key in REQUIRED_TOP_KEYS:
        if key not in data:
            problems.append(f"missing top-level key: {key}")

    steps = data.get("steps")
    if not isinstance(steps, list) or not steps:
        problems.append("'steps' must be a non-empty list")
        steps = []

    plugin_urls: list[str] = []
    for i, step in enumerate(steps):
        tag = f"steps[{i}]"
        if not isinstance(step, dict):
            problems.append(f"{tag} is not an object")
            continue
        name = step.get("step")
        if name not in KNOWN_STEPS:
            problems.append(f"{tag} unknown step: {name!r}")
        if name == "installPlugin":
            pd = step.get("pluginData", {})
            if isinstance(pd, dict) and pd.get("resource") == "url":
                url = pd.get("url")
                if isinstance(url, str):
                    plugin_urls.append(url)
                else:
                    problems.append(f"{tag} installPlugin missing url")

    if args.online:
        for url in plugin_urls:
            err = check_url(url)
            if err:
                problems.append(f"URL unreachable: {url}  ({err})")

    if problems:
        for p in problems:
            print(p, file=sys.stderr)
        print(f"\n{len(problems)} problem(s)", file=sys.stderr)
        return 1

    print(f"OK: blueprint.json ({len(steps)} steps, {len(plugin_urls)} plugin URL(s))")
    return 0


if __name__ == "__main__":
    sys.exit(main())
